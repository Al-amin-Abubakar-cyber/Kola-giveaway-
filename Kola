<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kola Giveaway - $1 Special Offer</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Arial', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            padding: 40px;
            max-width: 500px;
            text-align: center;
        }

        .header {
            margin-bottom: 30px;
        }

        .logo {
            font-size: 60px;
            margin-bottom: 15px;
        }

        h1 {
            color: #333;
            font-size: 32px;
            margin-bottom: 10px;
        }

        .tagline {
            color: #666;
            font-size: 16px;
            margin-bottom: 20px;
        }

        .price-section {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 30px;
            border-radius: 15px;
            margin-bottom: 30px;
        }

        .price-label {
            font-size: 18px;
            margin-bottom: 10px;
            opacity: 0.9;
        }

        .price {
            font-size: 48px;
            font-weight: bold;
            margin-bottom: 5px;
        }

        .description {
            font-size: 14px;
            opacity: 0.95;
            margin-bottom: 20px;
            color: #555;
        }

        .benefits {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 30px;
            text-align: left;
        }

        .benefits h3 {
            color: #333;
            margin-bottom: 15px;
            text-align: center;
        }

        .benefits ul {
            list-style: none;
        }

        .benefits li {
            color: #666;
            padding: 8px 0;
            border-bottom: 1px solid #e0e0e0;
        }

        .benefits li:last-child {
            border-bottom: none;
        }

        .benefits li:before {
            content: "✓ ";
            color: #667eea;
            font-weight: bold;
            margin-right: 10px;
        }

        .cta-button {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 15px 40px;
            font-size: 18px;
            border-radius: 50px;
            cursor: pointer;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            margin-bottom: 15px;
            width: 100%;
            font-weight: bold;
        }

        .cta-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
        }

        .secondary-button {
            background: white;
            color: #667eea;
            border: 2px solid #667eea;
            padding: 12px 30px;
            font-size: 16px;
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s ease;
            width: 100%;
            font-weight: bold;
        }

        .secondary-button:hover {
            background: #667eea;
            color: white;
        }

        .timer {
            margin-top: 20px;
            padding: 15px;
            background: #fff3cd;
            border-left: 4px solid #ffc107;
            border-radius: 5px;
            color: #856404;
            font-size: 14px;
        }

        .footer {
            margin-top: 30px;
            color: #999;
            font-size: 12px;
        }

        @media (max-width: 600px) {
            .container {
                padding: 25px;
            }

            h1 {
                font-size: 24px;
            }

            .price {
                font-size: 36px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="logo">🥜</div>
            <h1>Kola Giveaway</h1>
            <p class="tagline">Limited Time Offer</p>
        </div>

        <div class="price-section">
            <p class="price-label">Get Premium Kola for Just</p>
            <div class="price">$1.00</div>
            <p class="description">100% Authentic • Fresh Quality • Fast Delivery</p>
        </div>

        <p class="description">Join thousands of satisfied customers enjoying our premium kola products at unbeatable prices!</p>

        <div class="benefits">
            <h3>What You Get</h3>
            <ul>
                <li>Premium Quality Kola Nuts</li>
                <li>Free Shipping on Orders</li>
                <li>100% Money Back Guarantee</li>
                <li>Fresh Guarantee</li>
                <li>24/7 Customer Support</li>
            </ul>
        </div>

        <button class="cta-button" onclick="handlePurchase()">Claim Your $1 Offer Now</button>
        <button class="secondary-button" onclick="handleLearnMore()">Learn More</button>

        <div class="timer">
            ⏱️ This offer expires in: <strong>48 hours</strong>
        </div>

        <div class="footer">
            <p>© 2026 Kola Giveaway. All rights reserved.</p>
            <p>Privacy Policy | Terms of Service</p>
        </div>
    </div>

    <script>
        function handlePurchase() {
            alert('Thank you for your interest! Redirecting to payment...');
            // In a real application, this would redirect to a payment gateway
            // window.location.href = 'https://payment-gateway.com/checkout';
        }

        function handleLearnMore() {
            alert('Learn more about our premium kola products and benefits!');
            // In a real application, this would navigate to more information
        }
    </script>
</body>
</html>
